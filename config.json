{
    "ginmode": "debug",
    "loglevel": "debug",
    "server": {
        "mode": "PLAIN",
        "tls": {
            "certpath": "test/server.crt",
            "keypath": "test/server.key",
            "cacert": "test/cacert.pem"
        },
        "port": 8080,
        "upstream": "httpbin.org",
        "dropHeaders": [
            "Authorization"
        ],
        "injectHeaders": {
            "X-Aegis-Proxy": {
                "value": "true"
            },
            "Authorization": {
                "valueFromEnv": "UPSTREAM_AUTHORIZATION"
            }
        }
    },
    "kids": [
        "test"
    ]
}
